<%- include('partials/header') %>

<h1 class="mb-4">Gerenciar Produtos</h1>

<div class="row">
    <div class="col-md-4 mb-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Adicionar Produto</h5>
                <form action="/produtos" method="POST">
                    <div class="mb-3">
                        <label for="name" class="form-label">Nome:</label>
                        <input type="text" class="form-control" id="name" name="name" placeholder="Nome do produto" required>
                    </div>
                    <div class="mb-3">
                        <label for="description" class="form-label">Descrição:</label>
                        <input type="text" class="form-control" id="description" name="description" placeholder="Descrição" required>
                    </div>
                    <div class="mb-3">
                        <label for="price" class="form-label">Preço:</label>
                        <input type="number" class="form-control" id="price" name="price" placeholder="Preço" step="0.01" required>
                    </div>
                    <button type="submit" class="btn btn-success w-100">Adicionar</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <h5 class="mb-3">Produtos Cadastrados</h5>

        <% if (products.length === 0) { %>
            <div class="alert alert-info" role="alert">
                Nenhum produto cadastrado
            </div>
        <% } else { %>
            <div class="row">
                <% products.forEach(product => { %>
                    <div class="col-md-6 mb-3">
                        <div class="card">
                            <div class="card-body">
                                <h5 class="card-title"><%= product.name %></h5>
                                <p class="card-text"><strong>Descrição:</strong> <%= product.description %></p>
                                <p class="card-text"><strong>Preço:</strong> R$ <%= product.price.toFixed(2) %></p>
                                <div class="btn-group" role="group">
                                    <a href="/editar/<%= product.id %>" class="btn btn-sm btn-warning">Editar</a>
                                    <a href="/delete/<%= product.id %>" class="btn btn-sm btn-danger" onclick="return confirm('Deletar?')">Deletar</a>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </div>
</div>

<%- include('partials/footer') %>
