<%- include('partials/header') %>

<div class="row">
    <div class="col-md-8 offset-md-2">
        <div class="card">
            <div class="card-body">
                <h1 class="card-title">Contato</h1>
                
                <p class="mt-3">Entre em contato conosco:</p>

                <form class="mt-4" action="#" method="POST">
                    <div class="mb-3">
                        <label for="name" class="form-label">Nome:</label>
                        <input type="text" class="form-control" id="name" name="name" placeholder="Seu nome" required>
                    </div>

                    <div class="mb-3">
                        <label for="email" class="form-label">Email:</label>
                        <input type="email" class="form-control" id="email" name="email" placeholder="email@exemplo.com" required>
                    </div>

                    <div class="mb-3">
                        <label for="message" class="form-label">Mensagem:</label>
                        <textarea class="form-control" id="message" name="message" placeholder="Sua mensagem..." rows="5" required></textarea>
                    </div>

                    <button type="submit" class="btn btn-primary">Enviar</button>
                </form>

                <hr>

                <h2 class="mt-4">Outras Informações</h2>
                <ul>
                    <li>Email: exemplo@email.com</li>
                    <li>GitHub: <a href="https://github.com/BeFinkler/AplicacaoWebMVC" target="_blank">github.com/BeFinkler</a></li>
                </ul>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
